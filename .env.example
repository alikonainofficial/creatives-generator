GEMINI_API_KEY=your_gemini_api_key_here
FAL_KEY=your_fal_key_here
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
GOOGLE_SERVICE_ACCOUNT_JSON=./credentials/service_account.json
# Producer mode — Google Drive folder ID to upload final videos into
# (get from Drive folder URL: drive.google.com/drive/folders/<FOLDER_ID>)
GOOGLE_DRIVE_FOLDER_ID=your_drive_folder_id_here

# ── Pronunciation Fix (ElevenLabs TTS + Kling LipSync + Demucs) ──────────────
# Required to enable pronunciation fix (enable_pronunciation_fix=True by default).
# Get your key at: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
# Optional: override the default voice (Adam, American English male).
# Browse voices at: https://elevenlabs.io/voice-library
# If your persona is female, set a female voice ID here.
ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB
